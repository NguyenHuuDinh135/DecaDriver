# --- Project Configuration ---
PROJECT_NAME="DecaDriver AI"
SECRET_KEY="changethis_secret_key"
ENVIRONMENT="local"

# --- Database (Local Docker) ---
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app

# --- Superuser ---
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis_password

# --- AWS S3 Storage (Cloud Storage) ---
AWS_REGION=us-west-2
AI_S3_BUCKET=decadriver-assets-your-unique-id
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# No AWS_ENDPOINT_URL needed for standard S3

# --- AI Worker Configuration ---
AI_WORKER_TOKEN=generate_a_long_random_token_for_security

# --- Multi-Provider AI Stack (Zero-GPU Bypass) ---

# Fal.ai (Virtual Try-on & CLIP)
# Get key from: https://fal.ai/dashboard/keys
FAL_KEY=your_fal_key_here

# Google Colab (Qwen - Stylist Analysis)
# Get URL from ngrok after running Colab notebook
QWEN_API_URL=https://your-ngrok-id.ngrok-free.app/analyze
VIDEO_API_URL=https://your-video-ngrok-id.ngrok-free.app/generate-video

# Hugging Face Spaces (CatV2TON - Video Try-on)
# Get URL of the ZeroGPU Space
CATVTON_API_URL=https://your-username-catvton.hf.space/run/predict

# --- Legacy SageMaker (Optional/Local Fallback) ---
